# App
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=paytraka

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Paystack
PAYSTACK_SECRET_KEY_LIVE=sk_live_xxxx
PAYSTACK_SECRET_KEY_TEST=sk_test_xxxx
PAYSTACK_PUBLIC_KEY_LIVE=pk_live_xxxx
PAYSTACK_PUBLIC_KEY_TEST=pk_test_xxxx

# FIRS
FIRS_BASE_URL_LIVE=https://api.firs.gov.ng
FIRS_BASE_URL_TEST=https://test.firs.gov.ng
FIRS_CLIENT_ID_LIVE=your_live_client_id
FIRS_CLIENT_SECRET_LIVE=your_live_client_secret
FIRS_CLIENT_ID_TEST=your_test_client_id
FIRS_CLIENT_SECRET_TEST=your_test_client_secret

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_ACCESS_KEY=your_access_key
CLOUDFLARE_R2_SECRET_KEY=your_secret_key
CLOUDFLARE_R2_BUCKET=paytraka
CLOUDFLARE_R2_PUBLIC_URL=https://your-bucket.r2.dev

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=PayTraka <noreply@paytraka.com>
